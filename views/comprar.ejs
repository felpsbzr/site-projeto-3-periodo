<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Finalizar Compra - Base 5 Automações</title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body class="cadastro-body">
        <div class="cadastro-container">
            <main
                id="conteudo-principal"
                class="cadastro-card"
                tabindex="-1"
                aria-label="Página de pagamento"
            >
                <h1>Finalizar Compra</h1>
                <p>
                    Você está contratando o plano: <strong><%= plano %></strong>
                </p>

                <form
                    action="/comprar"
                    method="POST"
                    id="formCompra"
                    aria-label="Formulário de finalização de compra"
                >
                    <input type="hidden" name="plano" value="<%= plano %>" />

                    <div class="campo-nome">
                        <label for="nome">Nome Completo</label>
                        <input
                            type="text"
                            name="nome"
                            id="nome"
                            placeholder="João Silva"
                            required
                            minlength="3"
                            aria-required="true"
                        />
                    </div>

                    <div class="campo-email">
                        <label for="email">E-mail corporativo</label>
                        <input
                            type="email"
                            name="email"
                            id="email"
                            placeholder="joao.silva@empresa.com"
                            required
                            aria-required="true"
                        />
                    </div>

                    <div class="campo-cartao">
                        <label for="numeroCartao">Número do cartão</label>
                        <input
                            type="text"
                            name="cartao"
                            id="numeroCartao"
                            placeholder="1234 5678 9012 3456"
                            maxlength="19"
                            required
                            aria-required="true"
                        />
                    </div>

                    <div class="campos-cartao-inline">
                        <div class="campo-validade">
                            <label for="validade">Validade</label>
                            <input
                                type="text"
                                name="validade"
                                id="validade"
                                placeholder="MM/AA"
                                maxlength="5"
                                required
                                aria-required="true"
                                aria-label="Mês e ano de validade do cartão"
                            />
                        </div>

                        <div class="campo-cvv">
                            <label for="cvv">CVV</label>
                            <input
                                type="text"
                                name="cvv"
                                id="cvv"
                                placeholder="123"
                                maxlength="4"
                                required
                                aria-required="true"
                                aria-label="Código de segurança do cartão"
                            />
                        </div>
                    </div>

                    <div class="campo-nome-cartao">
                        <label for="nomeCartao">Nome como está no cartão</label>
                        <input
                            type="text"
                            name="nomeCartao"
                            id="nomeCartao"
                            placeholder="JOÃO SILVA"
                            required
                            minlength="3"
                            aria-required="true"
                        />
                    </div>

                    <div class="cadastro-botao" style="margin-top: 24px">
                        <a
                            href="/"
                            style="color: #1a56db; display: flex; align-items: center"
                            aria-label="Voltar para a página inicial"
                            >← Voltar</a
                        >
                        <button
                            type="submit"
                            class="botao-pronto"
                            aria-label="Confirmar compra do plano"
                        >
                            Confirmar Compra
                        </button>
                    </div>
                </form>
            </main>
        </div>

        <script>
            // Máscara para número do cartão: 1234 5678 9012 3456
            document.getElementById('numeroCartao').addEventListener('input', function (e) {
                let value = e.target.value.replace(/\s/g, '').replace(/\D/g, '');
                let formatted = value.match(/.{1,4}/g)?.join(' ') || value;
                e.target.value = formatted;
            });

            // Máscara para validade: MM/AA
            document.getElementById('validade').addEventListener('input', function (e) {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length >= 2) {
                    e.target.value = value.slice(0, 2) + '/' + value.slice(2, 4);
                } else {
                    e.target.value = value;
                }
            });

            // Máscara para CVV: apenas números
            document.getElementById('cvv').addEventListener('input', function (e) {
                e.target.value = e.target.value.replace(/\D/g, '');
            });

            // Validação básica antes de enviar
            document.getElementById('formCompra').addEventListener('submit', function (e) {
                const numeroCartao = document
                    .getElementById('numeroCartao')
                    .value.replace(/\s/g, '');
                const validade = document.getElementById('validade').value;
                const cvv = document.getElementById('cvv').value;

                if (numeroCartao.length !== 16) {
                    e.preventDefault();
                    alert('O número do cartão deve ter 16 dígitos');
                    return;
                }

                if (!/^\d{2}\/\d{2}$/.test(validade)) {
                    e.preventDefault();
                    alert('Validade deve estar no formato MM/AA');
                    return;
                }

                if (cvv.length < 3 || cvv.length > 4) {
                    e.preventDefault();
                    alert('CVV deve ter 3 ou 4 dígitos');
                    return;
                }
            });

            // Converte nome do cartão para maiúsculas automaticamente
            document.getElementById('nomeCartao').addEventListener('input', function (e) {
                e.target.value = e.target.value.toUpperCase();
            });
        </script>

        <div vw class="enabled">
            <div vw-access-button class="active"></div>
            <div vw-plugin-wrapper>
                <div class="vw-plugin-top-wrapper"></div>
            </div>
        </div>
        <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
        <script>
            new window.VLibras.Widget('https://vlibras.gov.br/app');
        </script>
    </body>
</html>
